// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Модели данных для мультитенантной HR системы холдинга

// Компания холдинга
model Company {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  shortName   String?    // Краткое название
  inn         String?    // ИНН компании
  address     String?
  phone       String?
  email       String?
  isActive        Boolean    @default(true)
  lunchBreakStart String?    @default("12:00") // Начало обеда (HH:mm)
  lunchBreakEnd   String?    @default("13:00") // Конец обеда (HH:mm)
  workDayStart    String?    @default("09:00") // Начало рабочего дня (HH:mm)
  workDayEnd      String?    @default("18:00") // Конец рабочего дня (HH:mm)
  workDays        String?    @default("1,2,3,4,5") // Рабочие дни недели (ISO: 1=Пн..7=Вс), через запятую
  sortOrder       Int        @default(0)
  users       User[]
  userAccesses UserCompany[]
  employees      Employee[]
  departments    Department[]
  positions      Position[]
  documents      EmployeeDocument[]
  inventoryItems   InventoryItem[]
  offices          Office[]
  attendanceEvents AttendanceEvent[]
  attendances      Attendance[]
  salaries             Salary[]
  doors                Door[]
  hikvisionDevices     HikvisionDevice[]
  agents               Agent[]
  registrationTokens   RegistrationToken[]
  unknownFaces         UnknownFace[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  password       String
  firstName      String?  // Имя пользователя
  lastName       String?  // Фамилия пользователя
  role           Role     @relation(fields: [roleId], references: [id])
  roleId         Int
  company        Company? @relation(fields: [companyId], references: [id])
  companyId      Int?     // null для суперадминов холдинга
  isHoldingAdmin    Boolean           @default(false) // Суперадмин холдинга
  isActive          Boolean           @default(true)
  extraCompanies    UserCompany[]     // Дополнительные компании (мультидоступ)
  initiatedCommands HikvisionCommand[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model UserCompany {
  userId    Int
  companyId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique // "Суперадмин", "Кадровик", "Руководитель", "Бухгалтер", "Сотрудник"
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id              Int                @id @default(autoincrement())
  firstName       String
  lastName        String
  patronymic      String?
  latinFirstName  String?
  latinLastName   String?
  birthDate       DateTime?
  passportSerial  String?
  passportNumber  String?
  passportIssuedBy String?
  passportIssueDate DateTime?
  inn             String?
  address         String?
  phone           String?
  email           String?
  salary          Float?
  contractNumber  String?
  contractDate    DateTime?
  hireDate        DateTime?
  status          String             @default("Активен") // "Активен", "Уволен", "В отпуске"
  notes           String?            @db.Text
  photoPath       String?            // Путь к фото сотрудника
  skudId          String?            // ID сотрудника в системе СКУД (Hikvision Face ID)
  company         Company            @relation(fields: [companyId], references: [id])
  companyId       Int
  department      Department?        @relation(fields: [departmentId], references: [id])
  departmentId    Int?
  position        Position?          @relation(fields: [positionId], references: [id])
  positionId      Int?
  documents        EmployeeDocument[]
  inventoryItems   InventoryItem[]
  attendanceEvents AttendanceEvent[]
  attendances      Attendance[]
  salaries         Salary[]
  positionHistory  PositionHistory[]
  doorAccesses       DoorAccess[]
  doorCommands       DoorCommand[]
  hikvisionAccesses  HikvisionAccess[]
  hikvisionCommands  HikvisionCommand[]
  managerId          Int?
  manager          Employee?          @relation("EmployeeHierarchy", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates     Employee[]         @relation("EmployeeHierarchy")
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([companyId])
  @@index([skudId])
  @@index([managerId])
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String
  company   Company    @relation(fields: [companyId], references: [id])
  companyId Int
  sortOrder Int        @default(0)
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([name, companyId]) // Уникальное название в рамках компании
  @@index([companyId])
}

model Position {
  id        Int        @id @default(autoincrement())
  name      String
  company   Company    @relation(fields: [companyId], references: [id])
  companyId Int
  employees Employee[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([name, companyId]) // Уникальное название в рамках компании
  @@index([companyId])
}

model EmployeeDocument {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  Int
  type       String   // "Паспорт", "ИНН", etc.
  filePath   String
  fileName   String
  uploadedBy String   // Можно будет связать с User ID
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([employeeId])
}

model InventoryItem {
  id              Int                @id @default(autoincrement())
  name            String
  model           String?
  category        String?    // Компьютеры, Мебель, Оргтехника, etc.
  inventoryNumber String?    // Инвентарный номер
  price           Float?
  acquisitionDate DateTime?  // Дата приобретения
  description     String?    @db.Text
  status          String     @default("В наличии") // В наличии, Выдан, В ремонте, Списан
  company         Company    @relation(fields: [companyId], references: [id])
  companyId       Int
  employee        Employee?  @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  employeeId      Int?
  history         InventoryHistory[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([inventoryNumber, companyId])
  @@index([companyId])
  @@index([employeeId])
}

model InventoryHistory {
  id              Int           @id @default(autoincrement())
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  inventoryItemId Int
  action          String        // "Создан", "Изменён", "Выдан", "Возвращён", "Удалён"
  details         String?       @db.Text
  employeeName    String?       // ФИО сотрудника (при выдаче/возврате)
  performedBy     String        // Email пользователя
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
}

model Office {
  id               Int               @id @default(autoincrement())
  name             String
  address          String?
  company          Company           @relation(fields: [companyId], references: [id])
  companyId        Int
  createdAt        DateTime          @default(now())
  attendanceEvents AttendanceEvent[]

  @@unique([name, companyId])
  @@index([companyId])
}

model AttendanceEvent {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  Int
  timestamp  DateTime
  direction  String   // "IN" | "OUT"
  deviceName String?
  office     Office?  @relation(fields: [officeId], references: [id])
  officeId   Int?
  source     String?  @default("HIKVISION") // "HIKVISION" | "QR_CHECKIN"
  selfiePath String?
  note       String?  @db.Text // комментарий сотрудника при мобильном чекине (где / на каком объекте)
  createdAt  DateTime @default(now())

  @@index([employeeId, timestamp])
  @@index([companyId, timestamp])
}

// Журнал «неизвестных людей» с устройств Hikvision:
// лицо не определено, отказ в доступе, либо ID не найден в БД
model UnknownFace {
  id            Int      @id @default(autoincrement())
  timestamp     DateTime
  reason        String   // no_id | face_not_matched | unknown_employee
  photoPath     String?  // фото с устройства (storage/unknown/...)
  rawEmployeeNo String?  // ID, пришедший с устройства (если был)
  deviceMac     String?
  deviceIp      String?
  officeName    String?
  direction     String?  // IN | OUT
  company       Company? @relation(fields: [companyId], references: [id])
  companyId     Int?
  reviewed      Boolean  @default(false) // отметка «разобрано»
  createdAt     DateTime @default(now())

  @@index([companyId, timestamp])
  @@index([timestamp])
}

model Attendance {
  id                Int      @id @default(autoincrement())
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId        Int
  company           Company  @relation(fields: [companyId], references: [id])
  companyId         Int
  date              DateTime @db.Date
  firstEntry        DateTime?
  lastExit          DateTime?
  status            String   @default("present") // present|left|absent|excused
  totalMinutes      Int      @default(0)
  correctionMinutes Int      @default(0)
  correctedBy       String?
  correctionNote    String?
  officeName        String?
  isLate                    Boolean   @default(false)
  isEarlyLeave              Boolean   @default(false)
  correctionType            String?   // "minutes" | "manual_in" | "manual_out" | "remote"
  correctionDeadline        DateTime? // До какого времени отпросился (сегодня HH:mm)
  correctionDeadlineNotified Boolean  @default(false) // TG уведомление об истечении отправлено
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([companyId, date])
}

model Salary {
  id              Int      @id @default(autoincrement())
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId      Int
  company         Company  @relation(fields: [companyId], references: [id])
  companyId       Int
  month           Int      // 1-12
  year            Int
  baseSalary      Float    @default(0) // Оклад
  workedDays      Int      @default(0) // Рабочих дней
  totalDays       Int      @default(0) // Всего рабочих дней в месяце
  workedHours     Int      @default(0) // Отработано минут
  bonus           Float    @default(0) // Премия
  deduction       Float    @default(0) // Удержание
  note            String?  @db.Text
  totalAmount     Float    @default(0) // Итого к выплате
  calculatedBy    String?  // Email кто рассчитал
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@index([companyId, month, year])
}

model PositionHistory {
  id             Int      @id @default(autoincrement())
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     Int
  companyId      Int
  departmentName String?  // Название отдела на момент записи
  positionName   String?  // Название должности на момент записи
  startDate      DateTime
  endDate        DateTime?
  note           String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([employeeId])
  @@index([companyId])
}

// Дверь офиса (одна дверь = два устройства Hikvision: вход + выход)
model Door {
  id            Int             @id @default(autoincrement())
  name          String          // "Главный вход", "Серверная"
  company       Company         @relation(fields: [companyId], references: [id])
  companyId     Int
  inDeviceIp    String          // IP входного устройства (снаружи)
  inDevicePort  Int             @default(80)
  outDeviceIp   String          // IP выходного устройства (внутри)
  outDevicePort Int             @default(80)
  login         String          @default("admin")
  password      String
  isActive      Boolean         @default(true)
  accesses      DoorAccess[]
  commands      DoorCommand[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([companyId])
}

// Очередь команд для relay-агента (выдать/отозвать доступ через локальный агент)
model DoorCommand {
  id         Int      @id @default(autoincrement())
  door       Door     @relation(fields: [doorId], references: [id], onDelete: Cascade)
  doorId     Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  action     String   // "grant" | "revoke"
  status     String   @default("pending") // pending | done | failed
  error      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, doorId])
  @@index([employeeId])
}

// Доступ сотрудника к двери
model DoorAccess {
  id         Int      @id @default(autoincrement())
  door       Door     @relation(fields: [doorId], references: [id], onDelete: Cascade)
  doorId     Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  grantedBy  String   // email кадровика/суперадмина
  createdAt  DateTime @default(now())

  @@unique([doorId, employeeId])
  @@index([employeeId])
  @@index([doorId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // e.g., "CREATE_EMPLOYEE", "UPLOAD_DOCUMENT"
  details   String   @db.Text
  userId    Int      // ID пользователя, совершившего действие
  companyId Int?     // ID компании (null для действий суперадмина)
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
}

// Автообнаруженные Hikvision устройства (по MAC-адресу)
model HikvisionDevice {
  id          Int      @id @default(autoincrement())
  macAddress  String   @unique
  lastSeenIp  String
  externalIp  String?
  deviceName  String?
  status      String   @default("pending") // "pending" | "active"
  company     Company? @relation(fields: [companyId], references: [id])
  companyId   Int?
  officeName  String?
  direction   String?                    // "IN" | "OUT"
  singleFaceId Boolean @default(false)   // одно устройство на дверь: направление вычисляется автоматически (первое событие сотрудника за день — вход, остальные — выход)
  login       String?  @default("admin")
  password    String?
  directPort  Int?                       // порт проброски роутера → устройство:80
  agent       Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentId     Int?
  lastSeenAt  DateTime @default(now())
  accesses    HikvisionAccess[]
  commands    HikvisionCommand[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([agentId])
  @@index([status])
}

// Очередь ISAPI-команд для relay-агента (Face ID: добавить/удалить пользователя)
model HikvisionCommand {
  id              Int             @id @default(autoincrement())
  device          HikvisionDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId        Int
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId      Int
  initiatedBy     User?           @relation(fields: [initiatedById], references: [id], onDelete: SetNull)
  initiatedById   Int?
  action          String          // "grant" | "revoke"
  status          String          @default("pending") // pending | processing | done | failed
  error           String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, deviceId])
  @@index([employeeId])
}

// Relay-агент в офисе (один агент на компанию или один на весь холдинг)
model Agent {
  id         Int       @id @default(autoincrement())
  agentId    String    @unique     // UUID, генерируется агентом один раз
  name       String                // Имя агента, напр. "Favz_Office"
  companyId  Int?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  devices    HikvisionDevice[]
  lastSeenAt DateTime?             // Время последнего ping
  version    String?               // Версия агента
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([companyId])
}

model RegistrationToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  company    Company  @relation(fields: [companyId], references: [id])
  companyId  Int
  isActive   Boolean  @default(true)
  createdBy  String
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([companyId])
}

// Доступ сотрудника к HikvisionDevice (Face ID)
model HikvisionAccess {
  id         Int             @id @default(autoincrement())
  device     HikvisionDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId   Int
  employee   Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  grantedBy  String
  createdAt  DateTime        @default(now())

  @@unique([deviceId, employeeId])
  @@index([employeeId])
  @@index([deviceId])
}

// ─────────── Telegram уведомления (настраиваемые) ───────────

// Глобальная конфигурация Telegram (singleton, id=1)
model TelegramConfig {
  id           Int      @id @default(1)
  defaultToken String?  // Токен бота по умолчанию (если у чата не задан свой)
  updatedAt    DateTime @updatedAt
}

// Чат-получатель уведомлений с маршрутизацией по категориям и компаниям
model TelegramChat {
  id         Int      @id @default(autoincrement())
  title      String                                 // Удобное имя ("Кадры Фавз", "Директор" и т.п.)
  chatId     String                                 // Telegram chat id (например -100123 или 12345)
  token      String?                                // Свой токен бота; если null — берётся defaultToken
  categories String   @default("")                  // CSV ключей категорий, напр. "attendance,late,registration"
  companyIds String   @default("")                  // CSV id компаний; пусто = все компании (глобально)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
